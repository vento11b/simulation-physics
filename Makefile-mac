CC = gcc

CFLAGS += -Iinclude -Llib
LDFLAGS += -lglfw
LDFLAGS += -framework OpenGL -framework Cocoa -framework IOKit -framework CoreVideo

LIB_DIR = lib
INCLUDE_DIR = include

GLFW_SRC_DIR = lib/glfw-3.4/src
GLFW_OBJ_DIR = lib/glfw-3.4/obj


GLFW_C_SRC = 	cocoa_time.c \
				context.c \
				egl_context.c \
				init.c \
				input.c \
				monitor.c \
				null_init.c \
				null_joystick.c \
				null_monitor.c \
				null_window.c \
				osmesa_context.c \
				platform.c \
				posix_module.c \
				posix_poll.c \
				posix_thread.c \
				posix_time.c \
				vulkan.c \
				window.c \
				

GLFW_OBJC_SRC = cocoa_init.m \
				cocoa_joystick.m \
				cocoa_monitor.m \
				cocoa_window.m \
				nsgl_context.m



GLFW_C_OBJ = $(GLFW_C_SRC:.c=.o)
GLFW_OBJC_OBJ = $(GLFW_OBJC_SRC:.m=.o)
GLFW_OBJ = $(GLFW_C_OBJ) $(GLFW_OBJC_OBJ)

$(GLFW_OBJ_DIR)/%.o: $(GLFW_SRC_DIR)/%.c
	$(CC) -D_GLFW_COCOA -c $< -o $@
$(GLFW_OBJ_DIR)/%.o: $(GLFW_SRC_DIR)/%.m
	$(CC) -D_GLFW_COCOA -ObjC -c $< -o $@

$(LIB_DIR)/libglfw.a: $(addprefix $(GLFW_OBJ_DIR)/, $(GLFW_OBJ))
	ar rcs $@ $^

sim: cleanobj cleanlib $(LIB_DIR)/libglfw.a
	$(CC) src/sim.c -o $@ $(CFLAGS) $(LDFLAGS)

glfw: $(LIB_DIR)/libglfw.a

	
nm: $(addprefix $(GLFW_OBJ_DIR)/, $(GLFW_OBJ))
	$(cleanobj)
	$(CC) -D_GLFW_COCOA -c  src/sim.c -o sim.o -Ilib/glfw-3.4/include
	gcc -r  sim.o $^ -framework OpenGL -framework Cocoa -framework IOKit -framework CoreVideo -o final.o 
	nm -u final.o

cleanlib:
	rm $(LIB_DIR)/libglfw.a
cleanobj:
	rm $(LIB_DIR)/glfw-3.4/obj/*.o